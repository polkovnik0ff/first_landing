# Запрещаем прямой доступ к конфигу и базе заявок
<Files "config.php">
    Order deny,allow
    Deny from all
</Files>

<Files "leads.csv">
    Order deny,allow
    Deny from all
</Files>

# submit.php доступен — он принимает POST от форм

# Security headers — обёрнуты в IfModule на случай если mod_headers
# отключён на хостинге (без обёртки вызвало бы 500 ошибку)
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>
